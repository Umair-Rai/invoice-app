<% if (!invoice) { %>
<main><p>Print Invoice #<%= id %> &mdash; not found.</p></main>
<% } else { %>
<%
  const ar = isArabic;
  const L = {
    salesInvoice:       ar ? 'فاتورة مبيعات'           : 'Sales Invoice',
    simplifiedTitle:    ar ? 'فاتورة ضريبية مبسطة'     : 'Simplified Tax Invoice',
    invoiceNo:          ar ? 'رقم الفاتورة'            : 'Invoice No',
    date:               ar ? 'التاريخ'                 : 'Date',
    paymentMethod:      ar ? 'طريقة الدفع'             : 'Payment Method',
    seller:             ar ? 'البائع'                  : 'Seller',
    customer:           ar ? 'العميل'                  : 'Customer',
    address:            ar ? 'العنوان'                 : 'Address',
    taxNumber:          ar ? 'الرقم الضريبي'           : 'Tax Number',
    phone:              ar ? 'الهاتف'                  : 'Phone',
    barcode:            ar ? 'باركود'                  : 'Barcode',
    itemName:           ar ? 'الصنف'                   : 'Items',
    unit:               ar ? 'الوحدة'                  : 'Unit',
    qty:                ar ? 'الكمية'                  : 'QTY',
    price:              ar ? 'السعر'                   : 'Price',
    total:              ar ? 'الإجمالي'                : 'Total',
    discount:           ar ? 'الخصم'                   : 'Discount',
    tax:                ar ? 'الضريبة'                 : 'TAX',
    net:                ar ? 'الصافي'                  : 'NET',
    subtotal:           ar ? 'المجموع'                 : 'Subtotal',
    taxableTotal:       ar ? 'الإجمالي الخاضع للضريبة' : 'Taxable Total',
    vatAmount:          ar ? 'مبلغ الضريبة'            : 'VAT',
    netIncVat:          ar ? 'الصافي شامل الضريبة'     : 'Net Including Tax',
    terms:              ar ? 'الشروط والأحكام'         : 'Terms & Conditions',
    customerSig:        ar ? 'توقيع العميل'            : 'Customer Signature',
    recipient:          ar ? 'المستلم'                 : 'The Recipient',
    ref:                ar ? 'المرجع'                  : 'REF',
    cash:               ar ? 'نقدي'                    : 'Cash',
    credit:             ar ? 'آجل'                     : 'Credit',
    bank:               ar ? 'تحويل بنكي'              : 'Bank Transfer',
  };
  const payLabel = invoice.payment_method === 'cash' ? L.cash
    : invoice.payment_method === 'credit' ? L.credit
    : invoice.payment_method === 'bank' ? L.bank
    : invoice.payment_method || '';

  const companyName = ar
    ? (settings.company_name_ar || settings.company_name || '')
    : (settings.company_name || '');
  const companyAddr = ar
    ? (settings.company_address_ar || settings.company_address || '')
    : (settings.company_address || '');
  const termsText = ar
    ? (settings.terms_conditions_ar || settings.terms_conditions || '')
    : (settings.terms_conditions || '');
  const taxableTotal = ((invoice.subtotal || 0) - (invoice.discount || 0));

  function fmt(n) { return Number(n || 0).toFixed(2); }
%>

<div class="invoice <%= ar ? 'rtl' : '' %>" dir="<%= ar ? 'rtl' : 'ltr' %>">

  <!-- ===== HEADER ===== -->
  <div class="inv-header">
    <div class="inv-header-left">
      <img src="/logo.png" alt="Logo" class="company-logo">
    </div>
    <div class="inv-header-right">
      <h1 class="inv-company-name"><%= companyName %></h1>
      <p class="company-tagline"><%= ar ? 'حلول أعمال احترافية' : 'Professional Business Solutions' %></p>
    </div>
  </div>

  <!-- ===== INVOICE INFO & CUSTOMER ===== -->
  <div class="inv-info-section">
    <div class="inv-info-left">
      <div class="info-row">
        <span class="info-label"><%= L.customer %>:</span>
        <span class="info-value"><%= invoice.customer_name || '—' %></span>
      </div>
      <div class="info-row">
        <span class="info-label"><%= L.phone %>:</span>
        <span class="info-value"><%= invoice.customer_phone || '—' %></span>
      </div>
      <div class="info-row">
        <span class="info-label"><%= L.address %>:</span>
        <span class="info-value"><%= invoice.customer_address || '—' %></span>
      </div>
      <div class="info-row">
        <span class="info-label"><%= L.taxNumber %>:</span>
        <span class="info-value"><%= invoice.customer_tax_number || '—' %></span>
      </div>
    </div>
    <div class="inv-info-right">
      <div class="info-row">
        <span class="info-label"><%= L.invoiceNo %>:</span>
        <span class="info-value"><%= invoice.invoice_no %></span>
      </div>
      <div class="info-row">
        <span class="info-label"><%= L.date %>:</span>
        <span class="info-value"><%= invoice.date %></span>
      </div>
    </div>
  </div>

  <!-- ===== SIMPLIFIED INVOICE TITLE BAR ===== -->
  <div class="inv-title-bar">
    <h2><%= L.simplifiedTitle %></h2>
  </div>

  <!-- ===== ITEMS TABLE ===== -->
  <table class="inv-items">
    <thead>
      <tr>
        <th class="col-idx">#</th>
        <th class="col-name"><%= L.itemName %></th>
        <th class="col-unit"><%= L.unit %></th>
        <th class="col-qty"><%= L.qty %></th>
        <th class="col-price"><%= L.price %></th>
        <th class="col-total"><%= L.total %></th>
        <th class="col-disc"><%= L.discount %></th>
        <th class="col-tax"><%= L.tax %></th>
        <th class="col-net"><%= L.net %></th>
      </tr>
    </thead>
    <tbody>
      <% items.forEach(function(item, i) { %>
      <% const lineTotal = (Number(item.quantity || 0) * Number(item.unit_price || 0)); %>
      <% const discPct = Number(item.discount || 0); %>
      <tr>
        <td class="col-idx"><%= i + 1 %></td>
        <td class="col-name"><%= item.description || '' %></td>
        <td class="col-unit"><%= item.unit || 'pc' %></td>
        <td class="col-qty"><%= item.quantity %></td>
        <td class="col-price"><%= fmt(item.unit_price) %></td>
        <td class="col-total"><%= fmt(lineTotal) %></td>
        <td class="col-disc"><%= discPct.toFixed(2) %>%</td>
        <td class="col-tax">—</td>
        <td class="col-net"><%= fmt(item.amount) %></td>
      </tr>
      <% }); %>
      <% if (items.length === 0) { %>
      <tr><td colspan="9" style="text-align:center;padding:1rem;">—</td></tr>
      <% } %>
    </tbody>
  </table>

  <!-- ===== TOTALS + QR ===== -->
  <div class="inv-bottom">
    <div class="inv-bottom-left">
      <div class="inv-qr-block">
        <img src="/QR.jpeg" alt="QR Code" class="qr-image">
      </div>
    </div>
    <div class="inv-bottom-right">
      <table class="totals-table">
        <% const totRows = [
          [L.discount, 'SAR ' + fmt(invoice.discount)],
          [L.taxableTotal, 'SAR ' + fmt(taxableTotal)],
          [L.vatAmount + ' ' + (invoice.vat_rate || 0) + '%', 'SAR ' + fmt(invoice.vat_amount)],
        ]; %>
        <% totRows.forEach(function(r) { %>
        <tr>
          <% if (ar) { %>
            <td class="t-value"><%= r[1] %></td>
            <td class="t-label"><%= r[0] %></td>
          <% } else { %>
            <td class="t-label"><%= r[0] %></td>
            <td class="t-value"><%= r[1] %></td>
          <% } %>
        </tr>
        <% }); %>
        <tr class="total-row">
          <% if (ar) { %>
            <td class="t-value">SAR <%= fmt(invoice.total) %></td>
            <td class="t-label"><%= L.netIncVat %></td>
          <% } else { %>
            <td class="t-label"><%= L.netIncVat %></td>
            <td class="t-value">SAR <%= fmt(invoice.total) %></td>
          <% } %>
        </tr>
      </table>
    </div>
  </div>

  <!-- ===== DIVIDER LINE ===== -->
  <div class="inv-divider"></div>

  <!-- ===== TERMS & CONDITIONS ===== -->
  <% if (termsText) { %>
  <div class="inv-terms">
    <h4><%= L.terms %></h4>
    <p><%= termsText %></p>
  </div>
  <% } %>
</div>

<% if (typeof autoprint !== 'undefined' && autoprint) { %>
<script>window.onload = function() { window.print(); };</script>
<% } %>
<% } %>
